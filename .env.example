# HMAC Authentication (padrão)
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Key Pair Authentication (Ed25519 — opcional, mais seguro)
# BINANCE_PRIVATE_KEY_PATH=/path/to/your/private_key.pem
# BINANCE_PRIVATE_KEY_PASSPHRASE=your_passphrase

# Agent Configuration
TRADING_MODE=paper
LOG_LEVEL=INFO
DB_PATH=db/crypto_agent.db
MODEL2_DB_PATH=db/modelo2.db
M2_EXECUTION_MODE=shadow
M2_LIVE_SYMBOLS=
M2_MAX_DAILY_ENTRIES=10
M2_MAX_MARGIN_PER_POSITION_USD=1.0
M2_MAX_SIGNAL_AGE_MINUTES=240
M2_SYMBOL_COOLDOWN_MINUTES=240
M2_SHORT_ONLY=true
M2_INJECTION_ENABLED=true
M2_CANARY_DB_PATH=db/modelo2_canary.db
M2_CANARY_LEVERAGE=3
M2_FUNDING_RATE_MAX_FOR_SHORT=0.0005
M2_REQUIRE_MAINNET_CONFIRM=true
M2_MAINNET_CONFIRM_TOKEN=
