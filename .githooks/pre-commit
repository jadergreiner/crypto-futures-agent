#!/usr/bin/python
"""PRE-COMMIT HOOK - DOC GOVERNANCE.

Valida markdown + docstrings antes de permitir commit.
Run: git config core.hooksPath .githooks
"""

from __future__ import annotations

import shutil
import subprocess
import sys
from pathlib import Path


REPO_ROOT = Path(__file__).resolve().parents[1]
DOCS_PATH_PREFIXES = ("docs/", "README.md")
DOCSTRING_DIR_PREFIXES = ("agent/", "execution/", "risk/", "backtest/")
DOCSTRING_SKIP_TOKENS = ("test", "check", "diagnostico")


def run(command: list[str], *, capture: bool = False) -> subprocess.CompletedProcess[str]:
    full_command = list(command)
    if full_command and full_command[0] == "git":
        full_command = [
            "git",
            "-c",
            f"safe.directory={REPO_ROOT.as_posix()}",
            "-C",
            str(REPO_ROOT),
            *full_command[1:],
        ]
    return subprocess.run(
        full_command,
        cwd=REPO_ROOT,
        check=False,
        text=True,
        capture_output=capture,
    )


def staged_files() -> list[str]:
    result = run(["git", "diff", "--cached", "--name-only", "--diff-filter=ACM"], capture=True)
    if result.returncode != 0:
        print("  [ERRO] Falha ao listar arquivos staged.")
        print(result.stderr.strip())
        sys.exit(1)
    return [line.strip() for line in result.stdout.splitlines() if line.strip()]


def validate_markdown(files: list[str]) -> None:
    print("  - Executando markdownlint...")
    markdown_files = [f for f in files if f.startswith("docs/") and f.endswith(".md")]
    if "README.md" in files:
        markdown_files.append("README.md")

    if not markdown_files:
        return

    _md_bin = shutil.which("markdownlint") or shutil.which("markdownlint.cmd")
    if _md_bin is None:
        print("  [AVISO] markdownlint nao encontrado. Install: npm install -g markdownlint-cli")
        return

    config_path = ".markdownlint.json" if (REPO_ROOT / ".markdownlint.json").exists() else ""
    autofix_cmd = [_md_bin]
    if config_path:
        autofix_cmd.extend(["--config", config_path])
    autofix_cmd.append("--fix")
    autofix_cmd.extend(markdown_files)
    run(autofix_cmd, capture=False)
    run(["git", "add", *markdown_files], capture=False)

    check_cmd = [_md_bin]
    if config_path:
        check_cmd.extend(["--config", config_path])
    check_cmd.extend(markdown_files)
    check = run(check_cmd, capture=True)
    if check.returncode != 0:
        print("  [ERRO] Markdownlint falhou apos auto-fix.")
        print(check.stdout.strip())
        print(check.stderr.strip())
        print("  Opcoes:")
        print("    1. Corrigir manualmente")
        print("    2. Usar script: python scripts/fix_markdown_lint.py <arquivo>")
        print("    3. Skip: git commit --no-verify")
        sys.exit(1)
    print(f"  [OK] Markdownlint: {', '.join(markdown_files)}")


def validate_docstrings(files: list[str]) -> None:
    print("  - Executando docstring checker...")
    python_files = [f for f in files if f.endswith(".py")]
    for rel_path in python_files:
        normalized = rel_path.replace("\\", "/")
        if any(token in normalized for token in DOCSTRING_SKIP_TOKENS):
            continue
        if not normalized.startswith(DOCSTRING_DIR_PREFIXES):
            continue
        file_path = REPO_ROOT / normalized
        if not file_path.exists():
            continue
        lines = file_path.read_text(encoding="utf-8").splitlines()
        if len(lines) <= 10:
            continue
        head = "\n".join(lines[:5])
        if '"""' not in head:
            print(f"  [ERRO] Docstring faltando: {normalized}")
            print("  Adicione docstring no inicio do arquivo.")
            sys.exit(1)
    if python_files:
        print("  [OK] Docstring checker.")


def validate_utf8(files: list[str]) -> None:
    print("  - Verificando encoding UTF-8...")
    for rel_path in files:
        file_path = REPO_ROOT / rel_path
        if not file_path.exists() or file_path.is_dir():
            continue
        try:
            file_path.read_text(encoding="utf-8")
        except UnicodeDecodeError:
            print(f"  [ERRO] Encoding invalido (nao UTF-8): {rel_path}")
            sys.exit(1)
    print("  [OK] Encoding UTF-8.")


def warn_sync(files: list[str]) -> None:
    print("  - Verificando [SYNC] para mudancas criticas...")
    touches_docs = any(path.startswith("docs/") or path == "README.md" for path in files)
    if touches_docs:
        print("  [AVISO] Mudanca em docs detectada.")
        print("  Use [SYNC] na mensagem de commit.")


def main() -> int:
    print("PRE-COMMIT: Validando documentacao...")
    files = staged_files()
    validate_markdown(files)
    validate_docstrings(files)
    validate_utf8(files)
    warn_sync(files)
    print("PRE-COMMIT: validacao completa.")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
